# .env.example — copy to .env and fill in real values

# ─── BAND Platform ────────────────────────────────────────────────────────────
# Get your BAND API key from https://app.band.ai/settings
BAND_API_KEY=band_a_your_key_here
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# ─── LLM Provider Keys (pick ONE) ────────────────────────────────────────────
# OpenRouter (recommended — gives access to many free models)
OVERALL_API_KEY=sk-or-v1-your_openrouter_key_here

# OR Anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# OR OpenAI
# OPENAI_API_KEY=sk-proj-your_key_here

# ─── Model Selection ──────────────────────────────────────────────────────────
# Primary model (used if an agent doesn't have a specific override)
LLM_MODEL=google/gemma-2-9b-it:free

# Per-agent model overrides (spreads rate-limit load across multiple models)
CONDUCTOR_MODEL=google/gemma-2-9b-it:free
PLANNER_MODEL=meta-llama/llama-3.3-70b-instruct:free
PLAN_REVIEWER_MODEL=meta-llama/llama-3.3-70b-instruct:free
CODER_MODEL=qwen/qwen-2.5-coder-32b-instruct:free
CODE_REVIEWER_MODEL=google/gemma-2-9b-it:free
TEST_ENGINEER_MODEL=qwen/qwen-2.5-coder-32b-instruct:free
DEBUGGER_MODEL=google/gemma-2-9b-it:free
MERGEMASTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── Git / GitHub ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
DEFAULT_BRANCH=main
AUTO_MERGE_THRESHOLD=low

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
