# Agent Configuration Template
#
# Copy this file to `agent_config.yaml` and fill in your real BAND agent IDs.
# Run `uv run code-assistant agents` to verify all agents are listed.
#
# To register agents on BAND platform, log in at https://app.band.ai,
# create an agent for each role below, and paste the IDs here.
# The BAND_API_KEY in .env is the same shared key for all agents.
#
# Example:
#   conductor:
#     agent_id: "agt_abc123..."
#
# If agent_id is left as the placeholder "${CONDUCTOR_AGENT_ID}", the system
# will skip platform WebSocket connection for that agent and fall back to
# the local in-process message bus (which is fine for local dev/testing).

agents:
  conductor:
    agent_id: "${CONDUCTOR_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "orchestrator"
    description: "Main orchestrator that coordinates all agents in the coding pipeline"

  planner:
    agent_id: "${PLANNER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "planner"
    description: "Breaks down user tasks into actionable implementation steps"

  plan_reviewer:
    agent_id: "${PLAN_REVIEWER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "reviewer"
    description: "Validates and refines implementation plans"

  coder:
    agent_id: "${CODER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "coder"
    description: "Implements code based on approved plans"

  code_reviewer:
    agent_id: "${CODE_REVIEWER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "reviewer"
    description: "Reviews code for quality, bugs, and best practices"

  test_engineer:
    agent_id: "${TEST_ENGINEER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "tester"
    description: "Creates and runs automated tests"

  debugger:
    agent_id: "${DEBUGGER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "debugger"
    description: "Identifies and fixes code issues"

  mergemaster:
    agent_id: "${MERGEMASTER_AGENT_ID}"
    api_key: "${BAND_API_KEY}"
    role: "merger"
    description: "Handles Git operations and manages pull requests"
